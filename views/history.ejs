<!DOCTYPE html>
<html lang="id">
<head>
    <title>Riwayat Transaksi - Inventaris Baterai</title>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar', { activePage: 'history' }) %>

    <main class="container-fluid px-4 pb-5">
        <section class="page-heading">
            <div>
                <p class="eyebrow mb-1"><%= admin && admin.role === "owner" ? "Owner" : admin && admin.role === "gudang" ? "Staff Gudang" : "Operasional" %></p>
                <h1>Riwayat Transaksi</h1>
                <p class="text-muted mb-0">
                    <% if (admin && admin.role === "owner") { %>
                        Semua perubahan stok masuk, penjualan, dan produksi tercatat di sini.
                    <% } else if (admin && admin.role === "gudang") { %>
                        Riwayat stok masuk dan stok dihapus yang kamu kelola.
                    <% } else { %>
                        Riwayat penjualan dan produksi yang kamu kelola.
                    <% } %>
                </p>
            </div>
            <span class="count-badge"><%= history.length %> log</span>
        </section>

        <section class="content-panel table-panel">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 warehouse-table">
                    <thead>
                        <tr>
                            <th class="text-center">No</th>
                            <th>Waktu</th>
                            <th>Barang</th>
                            <th>Aktivitas</th>
                            <th class="text-end">Jumlah</th>
                            <th class="text-end">Harga Satuan</th>
                            <th>Penanggung Jawab</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (history.length === 0) { %>
                            <tr>
                                <td colspan="8">
                                    <div class="empty-state py-5">
                                        <i class="bi bi-inbox"></i>
                                        <span>Belum ada riwayat transaksi.</span>
                                    </div>
                                </td>
                            </tr>
                        <% } %>

                        <% history.forEach((row, index) => { %>
                            <%
                                const jumlah = Number(row.jumlah_perubahan) || 0;
                                const isMasuk = jumlah > 0 || row.aktivitas === 'Stok Masuk' || row.aktivitas === 'Produksi-Masuk (Rakit)' || row.aktivitas === 'Masuk-Produksi';
                                const badgeClass =
                                    row.aktivitas === 'Penjualan' ? 'activity-sale' :
                                    row.aktivitas && row.aktivitas.includes('Keluar') ? 'activity-out' :
                                    isMasuk ? 'activity-in' : 'activity-neutral';
                                const isGudangAction = ['Stok Masuk', 'Stok Dihapus'].includes(row.aktivitas);
                                const isOperasionalAction = row.aktivitas === 'Penjualan' || (row.aktivitas && row.aktivitas.includes('Produksi'));
                                const penanggungLabel = isGudangAction ? 'gudang' : isOperasionalAction ? 'operasional' : null;
                            %>
                            <tr>
                                <td class="text-center text-muted"><%= index + 1 %></td>
                                <td class="text-muted small">
                                    <strong><%= row.waktu_format || '-' %></strong><br>
                                    <span>WIB</span>
                                </td>
                                <td>
                                    <div class="item-name"><%= row.nama_barang_tampil %></div>
                                </td>
                                <td>
                                    <span class="activity-badge <%= badgeClass %>"><%= row.aktivitas %></span>
                                </td>
                                <td class="text-end fw-semibold">
                                    <span class="<%= isMasuk ? 'text-success' : 'text-danger' %>">
                                        <%= isMasuk ? '+' : '-' %><%= Math.abs(jumlah).toLocaleString('id-ID') %> pcs
                                    </span>
                                </td>
                                <td class="text-end">
                                    <% if (Number(row.harga_satuan_log) > 0) { %>
                                        Rp <%= Number(row.harga_satuan_log).toLocaleString('id-ID') %>
                                    <% } else { %>
                                        <span class="text-muted">-</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (row.penanggung_jawab) { %>
                                        <div class="responsible-person">
                                            <i class="bi bi-person-fill text-muted"></i>
                                            <span><%= row.penanggung_jawab %></span>
                                            <% if (penanggungLabel) { %>
                                                <span class="responsible-tag"><%= penanggungLabel %></span>
                                            <% } %>
                                        </div>
                                    <% } else { %>
                                        <span class="text-muted">-</span>
                                    <% } %>
                                </td>
                                <td class="text-center">
                                    <span class="status-pill status-good">
                                        <i class="bi bi-check-circle"></i> Berhasil
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
