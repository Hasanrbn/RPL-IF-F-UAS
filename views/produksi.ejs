<!DOCTYPE html>
<html lang="id">
<head>
    <title>Produksi - Inventaris Baterai</title>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar', { activePage: 'produksi' }) %>

    <main class="container-fluid px-4 pb-5">
        <section class="page-heading">
            <div>
                <p class="eyebrow mb-1">Perakitan Internal</p>
                <h1>Modul Produksi</h1>
                <p class="text-muted mb-0">Ambil komponen dari gudang dan masukkan produk jadi dalam satu transaksi.</p>
            </div>
        </section>

        <form id="formProduksi" action="/produksi/proses-total" method="POST" class="content-panel mb-4">
            <div class="panel-title">
                <div>
                    <h2><i class="bi bi-cpu text-primary"></i> Form Perakitan</h2>
                    <p>Stok komponen akan berkurang, produk jadi akan otomatis masuk ke gudang.</p>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label">Nama Proyek Produksi</label>
                    <input type="text" name="nama_proyek" class="form-control" placeholder="Contoh: Batch Baterai Drone 3S" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Penanggung Jawab</label>
                    <input type="text" name="petugas" class="form-control" placeholder="Nama petugas" required>
                </div>
            </div>

            <div class="production-grid">
                <section class="production-section">
                    <h3><i class="bi bi-box-arrow-up text-danger"></i> Komponen Keluar</h3>
                    <div id="komponen-container">
                        <div class="komponen-row">
                        <select name="komponen_id[]" class="form-select komponen-select" required>
                            <option value="" data-harga="0">Pilih komponen</option>
                            <% daftar_barang.forEach(item => { %>
                                <option value="<%= item.id %>" data-harga="<%= Number(item.harga_jual || 0) %>">
                                    <%= item.nama_barang %> - <%= item.stok %> pcs - per pcs Rp <%= Number(item.harga_jual || 0).toLocaleString('id-ID') %>
                                </option>
                            <% }) %>
                        </select>
                            <input type="number" name="komponen_jumlah[]" class="form-control komponen-qty" placeholder="Qty" min="1" required>
                            <button type="button" class="btn btn-outline-danger icon-button" onclick="hapusBaris(this)" title="Hapus komponen">
                                <i class="bi bi-trash"></i>
                            </button>
                            <input type="hidden" name="komponen_harga_satuan[]" class="komponen-harga-hidden">
                        </div>
                    </div>
                    <button type="button" class="btn btn-outline-primary btn-sm mt-3" onclick="tambahBaris()">
                        <i class="bi bi-plus-circle"></i> Tambah Komponen
                    </button>
                </section>

                <section class="production-section">
                    <h3><i class="bi bi-box-arrow-down text-success"></i> Produk Jadi Masuk</h3>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Nama Produk</label>
                            <input type="text" name="produk_nama" class="form-control" placeholder="Nama produk hasil rakitan" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">SKU Produk</label>
                            <input type="text" name="produk_sku" class="form-control" placeholder="Contoh: BAT-3S-001" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Jumlah Jadi</label>
                            <input type="number" name="produk_jumlah" class="form-control" placeholder="0" min="1" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Total Modal</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="number" id="totalModalDisplay" name="produk_modal" class="form-control readonly-field" readonly>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Harga Jual / pcs</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input type="number" name="produk_harga" class="form-control" placeholder="0" min="0" required>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="form-actions">
                <button type="reset" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </button>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-save"></i> Simpan Produksi
                </button>
            </div>
        </form>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/produksi.js"></script>
</body>
</html>
